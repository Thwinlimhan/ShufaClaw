# Production environment template (no insecure defaults)
APP_ENV=production

# Core bot secrets
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
MY_TELEGRAM_ID=
DASHBOARD_PASSWORD=

# V2 infrastructure
DB_HOST=
DB_PORT=5432
DB_USER=
